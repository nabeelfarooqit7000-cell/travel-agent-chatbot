APP_NAME=Travel Agent Chatbot API
APP_ENV=development
HOST=127.0.0.1
PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000

SABRE_BASE_URL=https://api.cert.platform.sabre.com
SABRE_AUTH_URL=https://api.cert.platform.sabre.com/v2/auth/token
SABRE_FLIGHT_SHOP_PATH=/v5/offers/shop
SABRE_CLIENT_ID=your_sabre_client_id
SABRE_CLIENT_SECRET=your_sabre_client_secret
SABRE_CPA_ID=
SABRE_PCC=
SABRE_REQUESTOR_COMPANY_CODE=TN
SABRE_ISO_COUNTRY=PK
SABRE_TIMEOUT_SECONDS=30
ADMIN_SETUP_KEY=replace_with_long_random_secret
KNOWLEDGE_JSON_PATH=app/data/knowledge_base.json
KNOWLEDGE_BACKUP_DIR=app/data/backups
ADMIN_RATE_LIMIT_PER_MINUTE=30
